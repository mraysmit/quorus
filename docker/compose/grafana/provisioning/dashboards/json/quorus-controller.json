{
  "annotations": {
    "list": []
  },
  "description": "Quorus Controller Cluster Overview - Raft consensus with interactive network topology",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 1,
      "panels": [],
      "title": "Cluster Topology",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Live Raft topology with node states and directional peer links.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5A6C85", "value": null },
              { "color": "#E8B14A", "value": 1 },
              { "color": "#FF3B30", "value": 2 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "FOLLOWER", "index": 0 } }, "type": "value" },
            { "options": { "1": { "text": "CANDIDATE", "index": 1 } }, "type": "value" },
            { "options": { "2": { "text": "★ LEADER", "index": 2 } }, "type": "value" }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "State" }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 8, "x": 0, "y": 5 },
      "id": 100,
      "options": {
        "legend": {
          "showLegend": false
        }
      },
      "pluginVersion": "10.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_replace(label_replace(label_replace(label_replace(quorus_cluster_state{job=\"quorus-controllers-compose\",node=~\"controller1|controller2|controller3\"} == 0, \"detail__role\", \"FOLLOWER\", \"__name__\", \".*\"), \"color\", \"#4F6A8A\", \"__name__\", \".*\"), \"id\", \"$1\", \"node\", \"(.*)\"), \"title\", \"$1\", \"node\", \"(.*)\") or label_replace(label_replace(label_replace(label_replace(quorus_cluster_state{job=\"quorus-controllers-compose\",node=~\"controller1|controller2|controller3\"} == 1, \"detail__role\", \"CANDIDATE\", \"__name__\", \".*\"), \"color\", \"#D99B2B\", \"__name__\", \".*\"), \"id\", \"$1\", \"node\", \"(.*)\"), \"title\", \"$1\", \"node\", \"(.*)\") or label_replace(label_replace(label_replace(label_replace(quorus_cluster_state{job=\"quorus-controllers-compose\",node=~\"controller1|controller2|controller3\"} == 2, \"detail__role\", \"LEADER\", \"__name__\", \".*\"), \"color\", \"#FF2D55\", \"__name__\", \".*\"), \"id\", \"$1\", \"node\", \"(.*)\"), \"title\", \"$1\", \"node\", \"(.*)\")",
          "format": "table",
          "legendFormat": "{{node}}",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(sum by (source, target) (quorus_raft_rpc_ratio_total{job=\"quorus-controllers-compose\"}), \"id\", \"->\", \"source\", \"target\")",
          "format": "table",
          "legendFormat": "{{source}} -> {{target}}",
          "refId": "B",
          "instant": true
        }
      ],
      "title": "Raft Cluster Network",
      "type": "nodeGraph"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Detailed status of each cluster node with network addresses",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "center",
            "cellOptions": { "type": "color-text" },
            "inspect": false
          },
          "mappings": [
            { "options": { "0": { "color": "#3274D9", "index": 0, "text": "FOLLOWER" } }, "type": "value" },
            { "options": { "1": { "color": "#FF9830", "index": 1, "text": "CANDIDATE" } }, "type": "value" },
            { "options": { "2": { "color": "#73BF69", "index": 2, "text": "★ LEADER" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#3274D9", "value": null },
              { "color": "#FF9830", "value": 1 },
              { "color": "#73BF69", "value": 2 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Node" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "custom.cellOptions", "value": { "type": "color-text", "tooltipFromField": "Address", "tooltipPlacement": "top" } },
              { "id": "custom.align", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Address" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } },
              { "id": "custom.align", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Term" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Commit" },
            "properties": [
              { "id": "custom.width", "value": 70 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Log" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 16, "x": 8, "y": 5 },
      "id": 2,
      "options": {
        "cellHeight": "md",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "State" }]
      },
      "pluginVersion": "10.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quorus_cluster_state",
          "format": "table",
          "instant": true,
          "refId": "State"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quorus_cluster_term",
          "format": "table",
          "instant": true,
          "refId": "Term"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quorus_cluster_commit_index",
          "format": "table",
          "instant": true,
          "refId": "Commit"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "quorus_cluster_log_size",
          "format": "table",
          "instant": true,
          "refId": "LogSize"
        }
      ],
      "title": "Node Details",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "instance" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { 
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true,
              "otel_scope_name": true, "otel_scope_name 1": true, "otel_scope_name 2": true, "otel_scope_name 3": true, "otel_scope_name 4": true,
              "deployment 1": true, "deployment 2": true, "deployment 3": true, "deployment 4": true,
              "service 1": true, "service 2": true, "service 3": true, "service 4": true,
              "job 1": true, "job 2": true, "job 3": true, "job 4": true,
              "node 2": true, "node 3": true, "node 4": true
            },
            "indexByName": {
              "node 1": 0,
              "node": 0,
              "instance": 1,
              "Value #State": 2,
              "quorus_cluster_state": 2,
              "Value #Term": 3,
              "quorus_cluster_term": 3,
              "Value #Commit": 4,
              "quorus_cluster_commit_index": 4,
              "Value #LogSize": 5,
              "quorus_cluster_log_size": 5
            },
            "renameByName": {
              "node 1": "Node",
              "node": "Node",
              "instance": "Address",
              "Value #State": "State",
              "quorus_cluster_state": "State",
              "Value #Term": "Term",
              "quorus_cluster_term": "Term",
              "Value #Commit": "Commit",
              "quorus_cluster_commit_index": "Commit",
              "Value #LogSize": "Log",
              "quorus_cluster_log_size": "Log"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 4,
